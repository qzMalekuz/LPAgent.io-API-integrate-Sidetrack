# PostgreSQL connection string (used by both Prisma and Sidetrack job tables)
DATABASE_URL="postgresql://postgres:password@localhost:5432/lpagent_sidetrack?schema=public"

# LPAgent.io API key — register at https://portal.lpagent.io to get yours
# DM @thanhle27 on Telegram for the hackathon premium endpoint
LPAGENT_API_KEY="your_lpagent_api_key_here"

# Bot wallet — base58-encoded Solana private key used for signing zap transactions
# NEVER commit this value. Use a secrets manager in production.
WALLET_PRIVATE_KEY="your_base58_private_key_here"

# -----------------------------------------------------------------------
# Optional settings
# -----------------------------------------------------------------------

# HTTP server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV="development"

# Comma-separated Solana wallet addresses to monitor every 5 minutes
MONITOR_WALLETS="YourWalletPubkey1,YourWalletPubkey2"

# Set to "true" to enable automatic zap-out when positions go out of range
# When false (default), out-of-range positions only create Alert records
AUTOPILOT_ENABLED="false"

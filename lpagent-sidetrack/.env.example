# ---------------------------------------------------------------------------
# LP Copilot — environment template
# Copy to .env and fill in your values.
# ---------------------------------------------------------------------------

# PostgreSQL — required. Use Neon, Supabase, Railway, or local Postgres.
DATABASE_URL="postgresql://user:pass@host:5432/lpcopilot?sslmode=require"

# LP Agent API key — required.
# Get from https://portal.lpagent.io (DM @thanhle27 on Telegram for hackathon Premium).
LPAGENT_API_KEY=""

# Bot wallet private key (base58 Solana key) — required for zap signing.
# Use a dedicated, low-balance wallet. Never commit this.
WALLET_PRIVATE_KEY=""

# Comma-separated list of wallets to monitor automatically.
# These wallets will be polled every 5 minutes for out-of-range positions.
MONITOR_WALLETS=""

# When true, autopilot will auto-execute zap-out for out-of-range positions.
# When false (default), it will only create alerts.
AUTOPILOT_ENABLED="false"

# Telegram bot token — optional but highly recommended.
# Create one with @BotFather on Telegram and paste the token here.
# When set, users can /link their wallet and get push notifications.
TELEGRAM_BOT_TOKEN=""

# HTTP port for the API + dashboard.
PORT="3000"

NODE_ENV="development"

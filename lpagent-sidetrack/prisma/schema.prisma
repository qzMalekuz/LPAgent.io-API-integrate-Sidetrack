generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Meteora pools discovered via /pools/discover
// ---------------------------------------------------------------------------
model Pool {
  id               String   @id @default(uuid())
  poolId           String   @unique   // Meteora pool address (pubkey)
  name             String
  tokenX           String             // mint address
  tokenY           String             // mint address
  tokenXSymbol     String
  tokenYSymbol     String
  binStep          Int
  baseFeePercent   Float
  tvlUsd           Float    @default(0)
  volume24hUsd     Float    @default(0)
  apr              Float    @default(0)
  currentPrice     Float    @default(0)
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  positions        Position[]
  zapTransactions  ZapTransaction[]
  insights         Insight[]

  @@index([tvlUsd(sort: Desc)])
  @@index([apr(sort: Desc)])
  @@index([lastSyncedAt])
}

// ---------------------------------------------------------------------------
// LP positions owned by monitored wallets
// ---------------------------------------------------------------------------
model Position {
  id               String          @id @default(uuid())
  positionId       String          @unique   // on-chain position pubkey
  walletAddress    String
  poolId           String
  pool             Pool            @relation(fields: [poolId], references: [poolId])
  lowerBinId       Int
  upperBinId       Int
  activeBinId      Int
  inRange          Boolean
  totalXAmount     String          // raw token amount string
  totalYAmount     String
  feeX             String          @default("0")
  feeY             String          @default("0")
  valueUsd         Float           @default(0)
  feesEarnedUsd    Float           @default(0)
  lastCheckedAt    DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  alerts           Alert[]
  zapTransactions  ZapTransaction[]

  @@index([walletAddress])
  @@index([inRange])
  @@index([lastCheckedAt])
}

// ---------------------------------------------------------------------------
// Zap-in / zap-out transaction records
// ---------------------------------------------------------------------------
model ZapTransaction {
  id             String         @id @default(uuid())
  type           ZapType
  status         ZapStatus      @default(PENDING)
  walletAddress  String
  positionId     String?        // for zap-out
  poolId         String?        // for zap-in
  pool           Pool?          @relation(fields: [poolId], references: [poolId])
  position       Position?      @relation(fields: [positionId], references: [positionId])

  // Zap-in specific
  strategy       String?        // Spot | Curve | BidAsk
  fromBinId      Int?
  toBinId        Int?
  amountX        String?
  amountY        String?

  // Zap-out specific
  bps            Int?           // 0-10000 = percentage to withdraw
  outputMode     String?        // allToken0 | allToken1 | both

  // Execution result
  txSignature    String?        @unique
  errorMessage   String?
  slippageBps    Int            @default(50)
  estimatedValueUsd Float?

  // Source: who triggered it
  source         String         @default("api")  // api | telegram | autopilot | copylp | dashboard

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([walletAddress])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Alerts for out-of-range or anomalous positions
// ---------------------------------------------------------------------------
model Alert {
  id            String      @id @default(uuid())
  walletAddress String
  positionId    String
  position      Position    @relation(fields: [positionId], references: [positionId])
  type          AlertType   @default(OUT_OF_RANGE)
  status        AlertStatus @default(PENDING)
  message       String
  metadata      Json        @default("{}")
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([walletAddress])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Telegram users — link a Telegram chat to one or more Solana wallets
// ---------------------------------------------------------------------------
model TelegramUser {
  id             String   @id @default(uuid())
  chatId         String   @unique          // Telegram chat ID (string for safety)
  username       String?
  walletAddress  String?                   // primary wallet linked to this chat
  notifyAlerts   Boolean  @default(true)
  notifyZaps     Boolean  @default(true)
  notifyInsights Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([walletAddress])
}

// ---------------------------------------------------------------------------
// Copy-LP subscriptions — mirror a top LP's strategy on a target pool
// ---------------------------------------------------------------------------
model CopyLpSubscription {
  id              String   @id @default(uuid())
  followerWallet  String                     // wallet doing the copying
  leaderWallet    String                     // wallet being copied
  poolId          String                     // pool to mirror within
  capitalUsd      Float                      // notional size in USD to deploy
  strategy        String   @default("Curve") // Spot | Curve | BidAsk
  active          Boolean  @default(true)
  lastMirroredAt  DateTime?
  lastMirrorTxId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([followerWallet, leaderWallet, poolId])
  @@index([active])
  @@index([leaderWallet])
}

// ---------------------------------------------------------------------------
// AI-style insights generated for a wallet/pool (range recommendations,
// strategy suggestions, IL warnings, fee-velocity alerts, etc.)
// ---------------------------------------------------------------------------
model Insight {
  id            String       @id @default(uuid())
  walletAddress String?
  poolId        String?
  pool          Pool?        @relation(fields: [poolId], references: [poolId])
  type          InsightType
  severity      Severity     @default(INFO)
  title         String
  body          String
  data          Json         @default("{}")
  acknowledged  Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([walletAddress])
  @@index([poolId])
  @@index([type])
  @@index([createdAt])
}

enum ZapType {
  ZAP_IN
  ZAP_OUT
}

enum ZapStatus {
  PENDING
  SIGNED
  SUBMITTED
  CONFIRMED
  FAILED
}

enum AlertType {
  OUT_OF_RANGE
  LOW_LIQUIDITY
  HIGH_IMPERMANENT_LOSS
  FEE_SPIKE
  COPY_TRIGGER
}

enum AlertStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}

enum InsightType {
  RANGE_RECOMMENDATION
  STRATEGY_SUGGESTION
  IL_WARNING
  FEE_VELOCITY
  POOL_OPPORTUNITY
  PORTFOLIO_REBALANCE
}

enum Severity {
  INFO
  WARNING
  CRITICAL
}
